HF_TOKEN=

# Host path that will be mounted at /models inside the container.
MODEL_ROOT_HOST=/absolute/path/to/models

# Set these to 1 on first boot if you want the container to download/export
# the artifacts into MODEL_ROOT_HOST automatically.
AUTO_DOWNLOAD_BASE_CHECKPOINT=0
AUTO_DOWNLOAD_TURBO_S3=0
AUTO_EXPORT_VLLM_MODEL=0
